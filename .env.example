# ─── Microsoft Graph — App-Only Auth ─────────────────────────────────────────
# These credentials come from your Azure AD app registration.
# NEVER commit real values to version control.

TENANT_ID=your-tenant-id-here
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# ─── Target Mailbox ───────────────────────────────────────────────────────────
# UPN or object ID of the mailbox to read (requires Mail.Read app permission).
MAILBOX=mailbox@yourdomain.com
